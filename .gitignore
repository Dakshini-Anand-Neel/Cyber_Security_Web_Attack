# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── ML Artifacts (large binary files — track with DVC or Git LFS) ────────────
models/*.joblib
models/*.pkl
models/*.h5
models/*.pt
models/*.onnx
# Keep metadata JSON
!models/metadata.json

# ── Data (large files — track with DVC or Git LFS) ───────────────────────────
data/raw_train.csv
data/raw/*.csv
data/raw/*.parquet
data/interim/*.csv
data/processed/*.csv
data/processed/*.parquet
# Keep placeholder READMEs
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# ── Reports / Generated figures ───────────────────────────────────────────────
reports/figures/
reports/*.png
reports/*.jpg
# Keep text reports
!reports/classification_report.txt
!reports/model_comparison.csv

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Environment Variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Coverage / Testing ───────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Streamlit ────────────────────────────────────────────────────────────────
.streamlit/secrets.toml
